PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/elephant_db?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ENABLED=true
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Email Configuration (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email_account
EMAIL_PASS=your_email_app_password
EMAIL_FROM=Lanka Beacon <no-reply@example.com>
OTP_HASH_SECRET=replace_with_a_long_random_secret

# Alert Deduplication
ALERT_DEDUPE_WINDOW_MS=60000
ALERT_DEDUPE_DISTANCE_METERS=100

